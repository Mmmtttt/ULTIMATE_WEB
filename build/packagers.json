{
  "version": 1,
  "packagers": {
    "windows": {
      "type": "pyinstaller",
      "binary_name": "ultimate_backend_windows",
      "entry": "comic_backend/app.py",
      "mode": "onefile",
      "frontend_dist_dir": "comic_frontend_dist",
      "frontend_serve_path": "/"
    },
    "linux": {
      "type": "pyinstaller",
      "binary_name": "ultimate_backend_linux",
      "entry": "comic_backend/app.py",
      "mode": "onefile",
      "frontend_dist_dir": "comic_frontend_dist",
      "frontend_serve_path": "/"
    },
    "android": {
      "type": "capacitor",
      "app_id": "com.ultimate.web",
      "app_name": "UltimateWeb",
      "web_dir": "comic_frontend_dist",
      "workspace_web_dir": "web",
      "api_base_url": "",
      "embed_backend": true,
      "backend_port": 5000,
      "android_backend_enable_third_party": false,
      "chaquopy_version": "17.0.0",
      "chaquopy_python_version": "3.13",
      "chaquopy_min_sdk": 24,
      "embed_backend_requirements": [
        "flask==2.3.0",
        "flask-cors==4.0.0",
        "requests>=2.31.0",
        "PyYAML",
        "Pillow",
        "beautifulsoup4"
      ],
      "capacitor_core_version": "7",
      "capacitor_cli_version": "7",
      "capacitor_android_version": "7",
      "gradle_task": "assembleDebug",
      "apk_relative_path": "android/app/build/outputs/apk/debug/app-debug.apk"
    }
  }
}
