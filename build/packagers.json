{
  "version": 1,
  "packagers": {
    "windows": {
      "type": "pyinstaller",
      "binary_name": "ultimate_backend_windows",
      "entry": "comic_backend/app.py",
      "mode": "onefile",
      "frontend_dist_dir": "comic_frontend_dist",
      "frontend_serve_path": "/"
    },
    "linux": {
      "type": "pyinstaller",
      "binary_name": "ultimate_backend_linux",
      "entry": "comic_backend/app.py",
      "mode": "onefile",
      "frontend_dist_dir": "comic_frontend_dist",
      "frontend_serve_path": "/"
    },
    "android": {
      "type": "capacitor",
      "app_id": "com.ultimate.web",
      "app_name": "UltimateWeb",
      "icon_source": "comic_frontend/public/vite.jpg",
      "web_dir": "comic_frontend_dist",
      "workspace_web_dir": "web",
      "api_base_url": "",
      "embed_backend": true,
      "backend_port": 5000,
      "android_backend_enable_third_party": false,
      "chaquopy_version": "17.0.0",
      "chaquopy_python_version": "3.13",
      "chaquopy_min_sdk": 24,
      "android_signing_enabled": true,
      "android_signing_keystore": "build/android_signing/ultimate-release.keystore",
      "android_signing_module_keystore_name": "ultimate-release.keystore",
      "android_signing_key_alias": "ultimate",
      "android_signing_store_password": "ultimate123456",
      "android_signing_key_password": "ultimate123456",
      "android_signing_dname": "CN=Ultimate Web, OU=ULTIMATE_WEB, O=Mmmtttt, L=Internet, ST=Internet, C=CN",
      "android_signing_validity_days": 36500,
      "android_archive_tools_dir": "build/android_archive_tools",
      "android_archive_tool_binary_name": "7zz",
      "android_archive_tool_abis": [
        "arm64-v8a",
        "x86_64"
      ],
      "embed_backend_requirements": [
        "flask==2.3.0",
        "flask-cors==4.0.0",
        "requests>=2.31.0",
        "PyYAML",
        "Pillow",
        "beautifulsoup4",
        "rarfile>=4.2"
      ],
      "capacitor_core_version": "7",
      "capacitor_cli_version": "7",
      "capacitor_android_version": "7",
      "gradle_task": "assembleDebug",
      "apk_relative_path": "android/app/build/outputs/apk/debug/app-debug.apk"
    }
  }
}
