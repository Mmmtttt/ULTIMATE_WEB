{
  "version": 1,
  "packagers": {
    "windows": {
      "type": "pyinstaller",
      "binary_name": "ultimate_backend_windows",
      "entry": "comic_backend/app.py",
      "mode": "onefile"
    },
    "linux": {
      "type": "pyinstaller",
      "binary_name": "ultimate_backend_linux",
      "entry": "comic_backend/app.py",
      "mode": "onefile"
    },
    "android": {
      "type": "capacitor",
      "app_id": "com.ultimate.web",
      "app_name": "UltimateWeb",
      "web_dir": "comic_frontend_dist",
      "workspace_web_dir": "web",
      "capacitor_core_version": "latest",
      "capacitor_cli_version": "latest",
      "capacitor_android_version": "latest",
      "gradle_task": "assembleDebug",
      "apk_relative_path": "android/app/build/outputs/apk/debug/app-debug.apk"
    }
  }
}
